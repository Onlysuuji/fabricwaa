{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${authors}"
  ],
  "license": "${license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.example2.solips.SolipsClient"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
,
  "mixins": [
    "solips.client.mixins.json"
  ]
}
